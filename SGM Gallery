    font-weight:700;

    letter-spacing:1px;

}

.sgm-header p{

    color:#d7d7d7;

    font-size:18px;

    margin-top:12px;

}

/*==================================================
FILTER BAR
==================================================*/

.gallery-filter{

    display:flex;

    justify-content:center;

    flex-wrap:wrap;

    gap:14px;

    margin-bottom:60px;

    position:relative;

    z-index:5;

}

.filter-btn{

    background:rgba(255,255,255,.05);

    color:#fff;

    border:1px solid rgba(255,215,0,.35);

    padding:13px 24px;

    border-radius:40px;

    cursor:pointer;

    font-size:15px;

    transition:.35s;

    backdrop-filter:blur(12px);

}

.filter-btn:hover{

    transform:translateY(-4px);

    background:#FFD54A;

    color:#000;

    box-shadow:
        0 0 18px rgba(255,215,0,.45);

}

.filter-btn.active{

    background:#FFD54A;

    color:#000;

    font-weight:600;

    box-shadow:
        0 0 20px rgba(255,215,0,.55);

}

/*==================================================
GRID
==================================================*/

#gallery-grid{
    width:1400px;
    max-width:92%;
    margin:auto;

    display:grid;

    grid-template-columns:repeat(4,1fr);

    gap:28px;
}

@media(max-width:1200px){
    #gallery-grid{
        grid-template-columns:repeat(3,1fr);
    }
}

@media(max-width:768px){

    .sgm-header{

        padding:20px;

        margin-bottom:35px;

    }

    .sgm-logo{

        width:110px;

        height:auto;

        margin-bottom:15px;

    }

    .sgm-header h1{

        font-size:46px;

        line-height:1.1;

        margin:10px 0;

    }

    .sgm-header p{

        font-size:18px;

        line-height:1.5;

        padding:0 20px;

    }

}

@media(max-width:480px){
    #gallery-grid{
        grid-template-columns:1fr;
    }
}

/*==================================================
CARD
==================================================*/

.gallery-card{

    background:#111;

    border-radius:22px;

    overflow:hidden;

    cursor:pointer;

    transition:.45s;

    border:1px solid rgba(255,215,0,.18);

}

.gallery-card img{

    width:100%;

    aspect-ratio:3/4;

    object-fit:cover;

    display:block;

    transition:.45s;

}

.gallery-title{

    padding:18px;

    text-align:center;

    color:#FFD54A;

    font-size:18px;

    font-weight:600;

}

.gallery-card:hover{

    transform:
        translateY(-10px)
        scale(1.03);

    border-color:#FFD54A;

    box-shadow:
        0 20px 45px rgba(0,0,0,.45),
        0 0 22px rgba(255,215,0,.35);

}

.gallery-card:hover img{

    transform:scale(1.08);

}

/*==================================================
ANIMATION
==================================================*/

.gallery-card{

    animation:fadeUp .6s ease;

}

@keyframes fadeUp{

from{

    opacity:0;

    transform:
        translateY(35px);

}

to{

    opacity:1;

    transform:
        translateY(0);

}

}

/*==================================================
RESPONSIVE
==================================================*/

@media(max-width:768px){

.sgm-header h1{

    font-size:42px;

}

.sgm-logo{

    width:120px;

}

.gallery-filter{

    gap:10px;

}

.filter-btn{

    font-size:13px;

    padding:10px 18px;

}

#gallery-grid{

    grid-template-columns:
        repeat(2,1fr);

    gap:16px;

}

}

</style>


