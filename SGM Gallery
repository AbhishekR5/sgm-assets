    display:block;
    margin:0 auto 20px;

    border-radius:50%;

    object-fit:contain;

    background:#000;

    padding:6px;

    border:3px solid #FFD54A;

    box-shadow:
        0 0 25px rgba(255,215,0,.45);

}

/* Mobile */

@media(max-width:768px){

    .sgm-logo{

