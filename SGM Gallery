/*==================================================
BACKGROUND
==================================================*/

#sgm-gallery{
    position:relative;
    width:100vw;
    margin-left:calc(-50vw + 50%);
    padding:80px 0;
    overflow:hidden;

    background:
        radial-gradient(circle at top,#2b2508 0%,#0a0a0a 45%,#000 100%);

    color:#fff;
    font-family:"Poppins",sans-serif;
}

/* Gold Glow */

#sgm-gallery::before{
    content:"";
    position:absolute;
    width:700px;
    height:700px;
    left:50%;
    top:-350px;
    transform:translateX(-50%);
    border-radius:50%;
    background:rgba(255,196,0,.08);
    filter:blur(120px);
}

/*==================================================
HEADER
==================================================*/

.sgm-header{

