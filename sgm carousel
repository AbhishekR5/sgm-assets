(function(){

const carousel = document.getElementById("carousel3d");
if(!carousel) return;

const cards = [...carousel.querySelectorAll(".card")];

let radius = 760;
let rotation = 0;

let velocity = 0;
let targetVelocity = 0;

let dragging = false;
let lastPointerX = 0;

const cardCount = cards.length;
const step = 360 / cardCount;

/*---------------------------
Update Radius
----------------------------*/

function updateRadius(){

    if(window.innerWidth &lt; 768){

        radius = 420;

    }else{

        radius = 760;

    }

}

updateRadius();

/*---------------------------
Render Cards
----------------------------*/

function render(){

    cards.forEach((card,index)=&gt;{

        const angle = index * step + rotation;

        const rad = angle * Math.PI / 180;

        const z = Math.cos(rad);

        const scale = 0.82 + ((z+1)/2)*0.28;

        const opacity = 0.18 + ((z+1)/2)*0.82;

        const blur = (1-z)*1.4;

        card.style.transform = `
            rotateY(${angle}deg)
            translateZ(${radius}px)
            rotateZ(${Math.sin(rad)*5}deg)
            rotateX(${Math.cos(rad)*2.5}deg)
            scale(${scale})
        `;

        card.style.opacity = opacity;

        card.style.filter = `
            blur(${blur}px)
            brightness(${0.78 + ((z+1)/2)*0.22})
        `;

        card.style.zIndex = Math.floor((z+1)*100);

    });

    carousel.style.transform =
        "translate(-50%,-50%) rotateX(-8deg)";

}

/*---------------------------
Animation Loop
----------------------------*/

function animate(){

    targetVelocity *= 0.94;

    velocity += (targetVelocity - velocity) * 0.08;

    rotation += velocity;

    render();

    requestAnimationFrame(animate);

}

render();

requestAnimationFrame(animate);


