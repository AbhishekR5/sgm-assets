/* ==========================================================
   SGM LUXURY 3D CAROUSEL
   PART 2 - COMPLETE CSS
   Compatible with Odoo 19 Embedded HTML
========================================================== */

#sgm-carousel{
    position:relative;
    width:100vw;
    min-height:1050px;
    margin-left:calc(-50vw + 50%);
    overflow:hidden;

    background:
        radial-gradient(circle at top,
        #ffffff 0%,
        #f8f6f1 45%,
        #efe9dd 100%);

    font-family:
        "Cormorant Garamond",
        "Cinzel",
        Georgia,
        serif;
}

/* ==========================================================
   3D Stage
========================================================== */

#sgm-carousel .scene{

    position:relative;

    width:100%;
    height:1050px;

    perspective:2200px;
    perspective-origin:center center;

    overflow:visible;

}

/* ==========================================================
   Carousel
========================================================== */

#sgm-carousel .carousel{

    position:absolute;

    left:50%;
    top:34%;

    width:0;
    height:0;

    transform-style:preserve-3d;

    transform:
        translate(-50%,-50%);

}

/* ==========================================================
   Cards
========================================================== */

#sgm-carousel .card{

    position:absolute;

    width:270px;
    height:390px;

    left:-135px;
    top:-195px;

    transform-style:preserve-3d;

    transition:

        transform .8s cubic-bezier(.2,.8,.2,1),
        filter .8s,
        opacity .8s;

}

#sgm-carousel .card img{

    width:100%;
    height:100%;

    object-fit:cover;

    border-radius:18px;

    border:1px solid rgba(255,255,255,.4);

    box-shadow:

        0 15px 35px rgba(0,0,0,.12),

        0 30px 80px rgba(0,0,0,.18);

    transition:.6s;

}

#sgm-carousel .card:hover img{

    transform:

        scale(1.05);

    box-shadow:

        0 30px 80px rgba(0,0,0,.25);

}

/* ==========================================================
   Center Logo
========================================================== */

#sgm-carousel .center{

    position:absolute;

    left:50%;
    top:48%;

    transform:

        translate(-50%,-50%);

    width:600px;

    text-align:center;

    z-index:999;

    pointer-events:none;

}

/* ==========================================================
   Logo
========================================================== */

#sgm-carousel .center img{

    width:120px;

    margin-bottom:28px;

    filter:

        drop-shadow(0 0 25px rgba(207,166,70,.45));

}

/* ==========================================================
   Gold Gradient
========================================================== */

#sgm-carousel .gold{

    background:

        linear-gradient(

        180deg,

        #fff7c8 0%,

        #f9de83 15%,

        #f0c452 35%,

        #cf9b2d 55%,

        #f5d676 75%,

        #fff7d0 100%

        );

    -webkit-background-clip:text;
    -webkit-text-fill-color:transparent;

    background-clip:text;

}

/* ==========================================================
   SGM Title
========================================================== */

#sgm-carousel h1{

    margin:0;

    font-size:118px;

    line-height:1;

    font-weight:500;

    letter-spacing:8px;

    text-transform:uppercase;

    text-shadow:

        0 0 30px rgba(205,160,50,.12);

}

/* ==========================================================
   Creative Portfolio
========================================================== */

#sgm-carousel h2{

    margin-top:18px;

    font-size:34px;

    font-weight:400;

    letter-spacing:11px;

    text-transform:uppercase;

}

#sgm-carousel h2:before,
#sgm-carousel h2:after{

    content:"";

    display:inline-block;

    width:90px;
    height:1px;

    margin:0 25px;

    vertical-align:middle;

    background:

        linear-gradient(to right,

        transparent,

        #c89d2d,

        transparent);

}

/* ==========================================================
   Soft Glow
========================================================== */

#sgm-carousel .center:before{

    content:"";

    position:absolute;

    width:520px;
    height:520px;

    left:50%;
    top:42%;

    transform:

        translate(-50%,-50%);

    border-radius:50%;

    background:

        radial-gradient(circle,

        rgba(255,255,255,.75),

        rgba(255,255,255,0));

    z-index:-1;

}

/* ==========================================================
   Ambient Light
========================================================== */

#sgm-carousel:before{

    content:"";

    position:absolute;

    inset:0;

    background:

        radial-gradient(circle at center,

        rgba(255,255,255,.45),

        transparent 70%);

    pointer-events:none;

}

